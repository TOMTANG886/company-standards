{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["generated", "specs"],
  "properties": {
    "generated": { "type": "string" },
    "specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "project", "status", "version", "path", "authors", "created", "updated"],
        "properties": {
          "id":      { "type": "string" },
          "title":   { "type": "string" },
          "project": { "type": "string" },
          "status":  { "type": "string", "enum": ["draft", "review", "active", "deprecated"] },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "path":    { "type": "string" },
          "tags":    { "type": "array", "items": { "type": "string" } },
          "authors": { "type": "array", "items": { "type": "string" } },
          "created": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
